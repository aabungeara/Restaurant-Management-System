<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0" prefWidth="900.0" stylesheets="@../style/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.MenuController">

    <children>
        <HBox prefHeight="500.0" prefWidth="900.0">

            <children>

                <VBox prefWidth="300.0" spacing="15.0" styleClass="form-panel">
                    <padding>
                        <Insets bottom="25.0" left="20.0" right="20.0" top="25.0" />
                    </padding>

                    <Label styleClass="section-title" text="Menu Management" />

                    <TextField fx:id="nameField" promptText="Item Name" styleClass="input-field" />
                    <TextField fx:id="priceField" promptText="Price" styleClass="input-field" />
                    <ComboBox fx:id="categoryBox" promptText="Select Category" styleClass="input-field" />

                    <Button fx:id="addEditBtn" onAction="#handleAddOrEditMenuItem" styleClass="main-button" text="Add Menu Item" />
                    <Button onAction="#handleDeleteMenuItem" styleClass="danger-button" text="Delete Selected" />
                    <Button onAction="#backToDashboard" styleClass="secondary-button" text="Back to Dashboard" />
                </VBox>

                <VBox prefWidth="600.0" spacing="15.0" styleClass="table-panel">
                    <padding>
                        <Insets bottom="25.0" left="20.0" right="20.0" top="25.0" />
                    </padding>

                    <Label styleClass="section-title" text="Restaurant Menu Items" />

                    <HBox alignment="CENTER_LEFT" spacing="10">

                        <TextField fx:id="searchField" promptText="Search by Name" styleClass="input-field" />

                        <ComboBox fx:id="categoryFilterBox" promptText="Category" styleClass="input-field" />

                        <ComboBox fx:id="sortPriceBox" promptText="Sort Price" styleClass="input-field" />

                    </HBox>


                    
                    <TableView fx:id="tableView" prefHeight="420.0" prefWidth="560.0">
                        <columns>
                            <TableColumn fx:id="idColumn" prefWidth="80.0" text="ID" />
                            <TableColumn fx:id="nameColumn" prefWidth="180.0" text="Name" />
                            <TableColumn fx:id="priceColumn" prefWidth="140.0" text="Price" />
                            <TableColumn fx:id="categoryColumn" prefWidth="160.0" text="Category" />
                        </columns>
                    </TableView>
                </VBox>

            </children>

        </HBox>
    </children>
</AnchorPane>
