<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="520.0" prefWidth="930.0"
            stylesheets="@../style/style.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.OrdersController">

    <children>
        <HBox prefHeight="520.0" prefWidth="930.0">

            <children>

                <VBox prefWidth="310.0" spacing="15.0" styleClass="form-panel">
                    <padding>
                        <Insets top="25.0" right="20.0" bottom="25.0" left="20.0"/>
                    </padding>

                    <Label text="Orders Management" styleClass="section-title"/>

                    <ComboBox fx:id="tableBox" promptText="Select Table" styleClass="input-field"/>
                    <ComboBox fx:id="itemBox" promptText="Select Menu Item" styleClass="input-field"/>
                    <TextField fx:id="quantityField" promptText="Quantity" styleClass="input-field"/>
                    <ComboBox fx:id="statusBox" promptText="Select Status" styleClass="input-field"/>

                    <Button fx:id="addOrderBtn"
                            text="Add Order"
                            onAction="#handleAddOrder"
                            styleClass="main-button"/>
                    <Button text="Delete Selected"
                            onAction="#handleDeleteOrder"
                            styleClass="danger-button"/>

                    <Button text="Back to Dashboard"
                            onAction="#backToDashboard"
                            styleClass="secondary-button"/>
                </VBox>

                <VBox prefWidth="620.0" spacing="15.0" styleClass="table-panel">
                    <padding>
                        <Insets top="25.0" right="20.0" bottom="25.0" left="20.0"/>
                    </padding>

                    <Label text="Current Orders" styleClass="section-title"/>
                    
                    <TextField fx:id="searchField" promptText="Search by table, item, or status..." styleClass="input-field"/>
                    
                    <TableView fx:id="tableView" prefHeight="430.0" prefWidth="580.0">
                        <columns>
                            <TableColumn fx:id="idColumn" prefWidth="70.0" text="ID"/>
                            <TableColumn fx:id="tableNumberColumn" prefWidth="120.0" text="Table Number"/>
                            <TableColumn fx:id="itemNameColumn" prefWidth="180.0" text="Item Name"/>
                            <TableColumn fx:id="quantityColumn" prefWidth="110.0" text="Quantity"/>
                            <TableColumn fx:id="statusColumn" prefWidth="160.0" text="Status"/>
                        </columns>
                    </TableView>
                </VBox>

            </children>

        </HBox>
    </children>
</AnchorPane>