<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="550.0" prefWidth="850.0" stylesheets="@../style/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.SignUpController">

    <children>
        <VBox alignment="CENTER" layoutX="245.0" layoutY="50.0" prefHeight="450.0" prefWidth="360.0" spacing="10.0" styleClass="form-box" stylesheets="@../style/style.css">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <Label styleClass="title-label" stylesheets="@../style/style.css" text="Create Account" />
            <Label styleClass="sub-label" stylesheets="@../style/style.css" text="Restaurant Staff Registration" />

            <TextField fx:id="firstNameField" promptText="First Name" styleClass="input-field" stylesheets="@../style/style.css" />
            <TextField fx:id="lastNameField" promptText="Last Name" styleClass="input-field" stylesheets="@../style/style.css" />
            <TextField fx:id="emailField" promptText="Email" styleClass="input-field" stylesheets="@../style/style.css" />
            <PasswordField fx:id="passwordField" promptText="Password" styleClass="input-field" stylesheets="@../style/style.css" />
            <PasswordField fx:id="confirmPasswordField" promptText="Confirm Password" styleClass="input-field" stylesheets="@../style/style.css" />

            <Button mnemonicParsing="false" onAction="#handleSignUp" styleClass="main-button" stylesheets="@../style/style.css" text="Sign Up" />
            <Button mnemonicParsing="false" onAction="#goToLogin" styleClass="link-button" stylesheets="@../style/style.css" text="Back to Login" />
        </VBox>
    </children>
</AnchorPane>
