<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0" prefWidth="800.0" styleClass="root-dasbored" stylesheets="@../style/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.DashboardController">

    <children>
        <BorderPane prefHeight="500.0" prefWidth="800.0" stylesheets="@../style/style.css">

            <left>
                <VBox prefWidth="225.0" spacing="15.0" styleClass="sidebar" stylesheets="@../style/style.css">
                    <padding>
                        <Insets bottom="30.0" left="20.0" right="20.0" top="30.0" />
                    </padding>

                    <Label styleClass="sidebar-title" stylesheets="@../style/style.css" text="Restaurant System" />

                    <Button onAction="#goToTables" styleClass="nav-button" stylesheets="@../style/style.css" text="Tables" />
                    <Button onAction="#goToMenu" styleClass="nav-button" stylesheets="@../style/style.css" text="Menu" />
                    <Button onAction="#goToOrders" styleClass="nav-button" stylesheets="@../style/style.css" text="Orders" />
                    <Button onAction="#logout" styleClass="logout-button" stylesheets="@../style/style.css" text="Logout" />
                </VBox>
            </left>

            <center>
                <VBox alignment="CENTER" spacing="20.0" styleClass="dashboard-content">
                    <children>
                        <Label fx:id="welcomeLabel" styleClass="welcome-label" stylesheets="@../style/style.css" text="Welcome!" />
                        <Label styleClass="dashboard-text" stylesheets="@../style/style.css" text="Choose a section from the left menu to manage restaurant operations." wrapText="true" />
                    </children>
                </VBox>
            </center>

        </BorderPane>
    </children>
</AnchorPane>
